{
    "name": "atldays/laravel-agent",
    "description": "Laravel package for parsing user-agent strings into typed browser, operating system, device, and bot objects.",
    "keywords": [
        "laravel",
        "user-agent",
        "browser",
        "bot",
        "device",
        "operating-system",
        "device-detector",
        "atldays"
    ],
    "license": "MIT",
    "homepage": "https://github.com/atldays/laravel-agent",
    "support": {
        "issues": "https://github.com/atldays/laravel-agent/issues",
        "source": "https://github.com/atldays/laravel-agent"
    },
    "type": "library",
    "authors": [
        {
            "name": "Anjey Tsibylskij",
            "homepage": "https://github.com/atldays",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Atldays\\Agent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atldays\\Agent\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Atldays\\Agent\\AgentServiceProvider"
            ],
            "aliases": {
                "Agent": "Atldays\\Agent\\Facades\\Agent",
                "AgentManager": "Atldays\\Agent\\Facades\\AgentManager"
            }
        }
    },
    "require": {
        "php": "^8.2",
        "atldays/laravel-url": "^1.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "matomo/device-detector": "^6.5",
        "spatie/laravel-data": "^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "phpunit/phpunit": "^11.5|^12.5",
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "scripts": {
        "hooks:install": "git config core.hooksPath .githooks",
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "check": [
            "@format:test",
            "@test"
        ],
        "post-install-cmd": [
            "@hooks:install"
        ],
        "post-update-cmd": [
            "@hooks:install"
        ]
    }
}
