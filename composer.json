{
    "name": "atldays/laravel-agent",
    "description": "Laravel package for identifying user-agent details such as operating system, browser, bot, and device information.",
    "keywords": [
        "user-agent",
        "browser",
        "client",
        "laravel"
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "license": "MIT",
    "homepage": "https://github.com/atldays/laravel-agent",
    "type": "library",
    "authors": [
        {
            "name": "Anjey Tsibylskij",
            "homepage": "https://github.com/atldays",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Atldays\\Agent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atldays\\Agent\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Atldays\\Agent\\AgentServiceProvider"
            ],
            "aliases": {
                "Agent": "Atldays\\Agent\\Facades\\Agent"
            }
        }
    },
    "require": {
        "php": "^8.2",
        "matomo/device-detector": "^6.5",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "spatie/laravel-data": "^4.0",
        "atldays/laravel-url": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "phpunit/phpunit": "^11.5",
        "orchestra/testbench": "^9.0"
    },
    "scripts": {
        "hooks:install": "git config core.hooksPath .githooks",
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "check": [
            "@format:test",
            "@test"
        ],
        "post-install-cmd": [
            "@hooks:install"
        ],
        "post-update-cmd": [
            "@hooks:install"
        ]
    }
}
